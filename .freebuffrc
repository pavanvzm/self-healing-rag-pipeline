{
  "preview": {
    "name": "Self-Healing RAG Pipeline",
    "type": "nextjs",
    "commands": {
      "install": "cd frontend && bun install",
      "dev": "cd frontend && bun dev",
      "build": "cd frontend && bun run build"
    },
